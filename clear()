import java.util.ArrayList;

public class ClearDemo {
    public static void main(String[] args) {
        ArrayList<Integer> list = new ArrayList<>();

        list.add(100);
        list.add(200);
        list.add(300);

        System.out.println("Before clear: " + list);

        list.clear();

        System.out.println("After clear: " + list);
    }
}
