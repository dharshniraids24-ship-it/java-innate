import java.util.ArrayList;

public class AddGetDemo {
    public static void main(String[] args) {
        ArrayList<String> list = new ArrayList<>();

        list.add("Apple");
        list.add("Banana");
        list.add("Mango");

        System.out.println("List: " + list);
        System.out.println("Element at index 1: " + list.get(1));
    }
}
