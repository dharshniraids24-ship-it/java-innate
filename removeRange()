import java.util.ArrayList;
import java.util.Arrays;

class MyList<E> extends ArrayList<E> {
    public void removeRangePublic(int fromIndex, int toIndex) {
        super.removeRange(fromIndex, toIndex);
    }
}

public class RemoveRangeDemo {
    public static void main(String[] args) {
        MyList<Integer> list = new MyList<>();

        list.addAll(Arrays.asList(10, 20, 30, 40, 50, 60));

        list.removeRangePublic(1, 4); // removes index 1 to 3

        System.out.println("After removeRange: " + list);
    }
}
